import java.util.*;

abstract class VS{
	String name;
	String no;
	String type;
	VS(String name,String no,String type){
		this.name=name;
		this.no=no;
		this.type=type;
	}
	abstract double cscharge();
	void display() {
		System.out.println(name);
		System.out.println(no);
		System.out.println(type);
	}
}
class CService extends VS{
	double spcost;
	CService(String name,String no,String type,double spcost){
		super(name,no,type);
		this.spcost=spcost;
	}
	@Override
	double cscharge() {
		// TODO Auto-generated method stub
		
		return spcost+2000;
		
		
	}
	void display1(){
		display();
		System.out.println("Car");
		System.out.println(spcost);
		System.out.println(cscharge());
	}
}
class Bservice extends VS{
	double spcost;
	Bservice(String name,String no,String type,double spcost){
		super(name,no,type);
		this.spcost=spcost;
	}
	@Override
	double cscharge() {
		return spcost+800;
		 
	}
	void display2() {
		display();
		System.out.println("Bike");
		System.out.println(spcost);
		System.out.println(cscharge());
	
	}
}
